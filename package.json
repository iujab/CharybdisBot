{
  "name": "azurlane-discord-bot",
  "version": "1.0.0",
  "description": "Azur Lane ship info Discord bot using AzurAPI",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "deploy-commands": "tsc && node dist/deploy-commands.js",
    "pm2": "npm run build && pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop azurlane-bot",
    "pm2:restart": "pm2 restart azurlane-bot",
    "pm2:logs": "pm2 logs azurlane-bot"
  },
  "dependencies": {
    "@lycoristech/azurapi": "^0.0.4",
    "discord.js": "^14.14.1",
    "dotenv": "^16.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "typescript": "^5.3.3"
  }
}
